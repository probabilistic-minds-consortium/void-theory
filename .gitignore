# === Void Theory .gitignore ===

# Coq build artifacts
*.vo
*.vok
*.vos
*.glob
*.aux
.*.aux

# Coq build scripts output
coq/out.txt
coq/tmp_out.txt
coq/_CoqProject

# Python
__pycache__/
*.pyc
venv/
*.egg-info/

# OS junk
.DS_Store
Thumbs.db
~$*

# Editor temp files
*.swp
*.swo
*~
\#*\#

# Word lock files (already covered by ~$* but explicit)
# ~$*.docx

# Beckett analysis (local experiments, not part of theory)
beckett_*.py
beckett_*.json
beckett_*.csv

# Legacy files
void_wild.v
